# === Python Environment & Caching ===
__pycache__/
*.py[cod]
*$py.class
venv/
env/
.venv/
# Keep your manual tracking exclusion safe
Lib/

# === LabVIEW Local User & Build Files ===
# Local project aliases (contains machine-specific IP/target mappings)
*.aliases
# Local project settings (tracks which windows you had open)
*.lvlps
# Compiled build directories
/Builds/
# Error logs automatically generated by the LabVIEW runtime
lv_err.log

# === Databases & High-Speed Telemetry Logs ===
# Ignore raw local database files to prevent repository bloat
*.db
*.sqlite
*.sqlite3
# Ignore raw high-speed binary waveform files if logging locally
*.tdms
*.tdms_index

# === OS & System Clutter ===
Thumbs.db
Desktop.ini
.DS_Store